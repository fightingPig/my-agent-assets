{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "My Agent Assets",
  "version": "0.1.0",
  "identifier": "com.fightingpig.myagentassets",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:renderer",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "My Agent Assets",
        "width": 1440,
        "height": 900,
        "minWidth": 1180,
        "minHeight": 760,
        "center": true,
        "decorations": true,
        "resizable": true,
        "shadow": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["all"],
    "category": "DeveloperTool",
    "shortDescription": "Manage local Claude assets",
    "copyright": "Copyright © 2026 My Agent Assets",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-"
    }
  }
}
